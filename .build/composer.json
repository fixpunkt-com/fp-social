{
  "name": "fixpunkt/fp-social-cs-tools",
  "description": "Isolated tooling to static-analyse fp_social against TYPO3 14.3 (highest supported).",
  "autoload": {
    "psr-4": {
      "Fixpunkt\\FpSocial\\": "../Classes/"
    }
  },
  "require-dev": {
    "typo3/coding-standards": "^0.8",
    "phpstan/extension-installer": "^1.4",
    "saschaegerer/phpstan-typo3": "^3",
    "typo3/cms-core": "^14.3",
    "typo3/cms-extbase": "*",
    "typo3/cms-fluid": "*",
    "typo3/cms-frontend": "*",
    "typo3/cms-backend": "*",
    "typo3/cms-install": "*",
	  "fixpunkt/fp-social-bridge": "^1.3",
    "league/uri": "^7.0",
    "league/uri-components": "^7.0",
    "chefkoch/morphoji": "^1.1"
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true,
      "phpstan/extension-installer": true
    }
  }
}
