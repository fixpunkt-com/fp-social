{
  "name": "fixpunkt/fp-social-cs-tools-v14",
  "description": "Isolated tooling to static-analyse fp_social against TYPO3 14.4 (highest supported). Mirror of .build/ but pinned to the v14 line.",
  "autoload": {
    "psr-4": {
      "Fixpunkt\\FpSocial\\": "../Classes/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpstan/extension-installer": "^1.4",
    "saschaegerer/phpstan-typo3": "^2.1",
    "typo3/cms-core": "^14.3",
    "typo3/cms-extbase": "*",
    "typo3/cms-fluid": "*",
    "typo3/cms-frontend": "*",
    "typo3/cms-backend": "*",
    "typo3/cms-install": "*",
  	"fixpunkt/fp-social-bridge": "dev-feature/typo3-14",
    "league/uri": "^7.0",
    "league/uri-components": "^7.0",
    "chefkoch/morphoji": "^1.1"
  },
  "config": {
    "allow-plugins": {
      "typo3/class-alias-loader": true,
      "typo3/cms-composer-installers": true,
      "phpstan/extension-installer": true
    }
  }
}
